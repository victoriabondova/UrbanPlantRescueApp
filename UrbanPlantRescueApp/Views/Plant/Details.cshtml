@model UrbanPlantRescueApp.ViewModels.PlantViewModel

@{
    ViewData["Title"] = "Детайли за растението";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h2>@Model.Name</h2>
        </div>
        <div class="card-body">
            <h5 class="card-subtitle mb-2 text-muted">Категория: @Model.CategoryName</h5>
            <p class="card-text mt-3">@Model.Description</p>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Name" />
            }
            else
            {
                <p class="text-muted">Няма зададена снимка за това растение.</p>
            }
        </div>
        <hr />
        <h4>Заявки за спасяване на това растение:</h4>

        @if (ViewBag.Requests != null && ((IEnumerable<RescueRequestViewModel>)ViewBag.Requests).Any())
        {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Дата</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in (IEnumerable<RescueRequestViewModel>)ViewBag.Requests)
                    {
                        <tr>
                            <td>@request.RequesterEmail</td>
                            <td>@request.RequestDate.ToShortDateString()</td>
                            <td>@request.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>Все още няма заявки за това растение.</p>
        }
        <div class="card-footer">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактирай</a>
            <a asp-action="Index" class="btn btn-secondary">Назад към списъка</a>
        </div>
        <div class="card-footer d-flex gap-2">
            @if (User.Identity.IsAuthenticated)
            {
                <form asp-controller="RescueRequest" asp-action="Create" method="post">
                    <input type="hidden" name="plantId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">Спаси това растение!</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success">Влезте, за да спасите</a>
            }
        </div>

    </div>
</div>