@{
    ViewData["Title"] = "Home";
}

<section class="bg-light py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold">Urban Plant Rescue App</h1>
                <p class="text-muted fs-5">Helping communities identify, report and revive distressed plants across the city — a practical sample built with ASP.NET Core Razor pages and .NET 8.</p>

                <ul class="list-unstyled d-flex flex-column flex-sm-row gap-2 mt-4">
                    <li><a asp-controller="Category" asp-action="Index" class="btn btn-primary btn-lg">Browse Categories</a></li>
                    <li><a href="https://github.com/victoriabondova/UrbanPlantRescueApp" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-lg">View Source</a></li>
                </ul>

                <p class="text-muted small mt-4">Built with modern web standards, accessibility in mind, and a focus on a clean, responsive UI.</p>
            </div>

            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex align-items-start">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="me-3 text-success" aria-hidden="true">
                                <path d="M12 2c0 4-5 7-5 11 0 4 2 7 5 7s5-3 5-7c0-4-5-7-5-11z" fill="#198754"/>
                            </svg>
                            <div>
                                <h6 class="mb-1">Project</h6>
                                <p class="mb-0 text-muted small">A compact sample demonstrating Razor views, controllers and basic CRUD for learning purposes.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5">
            <div class="col-12">
                <h2 class="h4">Key features</h2>
            </div>

            <div class="col-md-4 mt-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Organized Categories</h5>
                        <p class="card-text text-muted">Easily browse and manage plant categories to keep reports structured and searchable.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mt-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Responsive UI</h5>
                        <p class="card-text text-muted">Mobile-first layout using Bootstrap ensures the app looks great on all devices.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mt-3">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Educational</h5>
                        <p class="card-text text-muted">Designed as an instructional sample for .NET 8, C# 12, and Razor Pages patterns.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
